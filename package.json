{
  "name": "@mosierdata/emdash-plugin-analytics",
  "version": "1.0.2",
  "description": "Tag Manager, Call Tracking, and Marketing Analytics for EmDash",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./descriptor": {
      "types": "./dist/descriptor.d.mts",
      "import": "./dist/descriptor.mjs"
    },
    "./admin": {
      "types": "./dist/admin.d.mts",
      "import": "./dist/admin.mjs"
    }
  },
  "files": [
    "dist",
    "patches"
  ],
  "scripts": {
    "prepack": "npm run build",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bundle": "emdash plugin bundle",
    "deploy": "emdash plugin publish --build"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "emdash": "^0.1.0",
    "jsdom": "^24.0.0",
    "patch-package": "^8.0.1",
    "tsdown": "0.20.3",
    "typescript": "^5.4.0",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "@emdash-cms/admin": "*",
    "emdash": "^0.1.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {}
}
